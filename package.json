{
  "name": "vmarkd",
  "displayName": "vMarkd — Visual Markdown Editor",
  "icon": "media/logo.png",
  "description": "vMarkd — a full-featured visual markdown editor.",
  "version": "0.4.16",
  "publisher": "spiochacz",
  "author": "Sławomir Piochacz",
  "license": "MIT",
  "private": false,
  "engines": {
    "vscode": "^1.110.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "vMark renders and edits markdown, but defers writing images and creating wiki pages until the workspace is trusted."
    },
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "Editing works; features that depend on the local filesystem (image upload, wiki page creation, asset resolution) are unavailable in virtual workspaces."
    }
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "vmarkd",
    "visual-markdown",
    "markdown",
    "editor",
    "wysiwyg",
    "typora",
    "markdown-previewer",
    "markdown-editor"
  ],
  "activationEvents": [
    "onCommand:markdown-editor.openEditor",
    "onCommand:markdown-editor.openTextEditor",
    "onCustomEditor:markdown-editor.editor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/spiochacz/vmarkd-visual-markdown-editor.git"
  },
  "main": "out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdown-editor.openEditor",
        "title": "Open with markdown editor",
        "category": "markdown-editor",
        "icon": {
          "light": "media/open-markdown-light.svg",
          "dark": "media/open-markdown-dark.svg"
        }
      },
      {
        "command": "markdown-editor.openTextEditor",
        "title": "Edit in Text Editor",
        "category": "markdown-editor",
        "icon": {
          "light": "media/open-editor-light.svg",
          "dark": "media/open-editor-dark.svg"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "markdown-editor.editor",
        "displayName": "Visual Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md",
            "scheme": "file"
          },
          {
            "filenamePattern": "*.md",
            "scheme": "untitled"
          },
          {
            "filenamePattern": "*.markdown",
            "scheme": "file"
          },
          {
            "filenamePattern": "*.markdown",
            "scheme": "untitled"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceLangId == markdown",
          "command": "markdown-editor.openEditor",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "when": "!isInDiffEditor && activeCustomEditorId != markdown-editor.editor && (resourceExtname == .md || resourceExtname == .markdown) && (resourceScheme == file || resourceScheme == untitled)",
          "command": "markdown-editor.openEditor",
          "group": "navigation@10"
        }
      ],
      "editor/title/context": [
        {
          "when": "activeCustomEditorId == markdown-editor.editor",
          "command": "markdown-editor.openTextEditor",
          "group": "1_open"
        }
      ],
      "commandPalette": [
        {
          "command": "markdown-editor.openEditor",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "markdown-editor",
      "properties": {
        "markdown-editor.imageSaveFolder": {
          "type": "string",
          "default": "assets",
          "description": "Save images to which folder when upload in markdown, default relative to the markdown file, you can set to project root via `${projectRoot}/assets`."
        },
        "markdown-editor.useVscodeThemeColor": {
          "type": "boolean",
          "default": true,
          "description": "Use vscode theme's background color as the markdown editor's background color."
        },
        "markdown-editor.customCss": {
          "type": "string",
          "default": ""
        },
        "markdown-editor.enableFullWidth": {
          "type": "boolean",
          "default": true,
          "description": "Enable full-width layout for the editor (removes max-width centering)."
        },
        "markdown-editor.wordCount": {
          "type": "boolean",
          "default": false,
          "description": "Show a live word/character count. Off by default — the count recomputes on every keystroke, which can be costly in large documents."
        },
        "markdown-editor.codeBlockLineNumbers": {
          "type": "boolean",
          "default": false,
          "description": "Show line numbers in fenced code blocks (rendered preview). Off by default — adds a line-number gutter per code block."
        },
        "markdown-editor.showToolbar": {
          "type": "boolean",
          "default": true,
          "description": "Show the editor toolbar. When off, the editor opens without a toolbar."
        },
        "markdown-editor.retainHiddenEditors": {
          "type": "boolean",
          "default": true,
          "description": "Keep hidden editor tabs alive for instant switching. Turn off to free memory when many tabs are open (each hidden editor is fully retained), at the cost of a reload when you switch back. Changing this requires reloading the window."
        }
      }
    },
    "keybindings": [
      {
        "key": "ctrl+alt+e",
        "command": "markdown-editor.openTextEditor",
        "mac": "cmd+ctrl+e",
        "when": "activeCustomEditorId == markdown-editor.editor"
      },
      {
        "key": "ctrl+f",
        "command": "editor.action.webvieweditor.showFind",
        "mac": "cmd+f",
        "when": "activeCustomEditorId == markdown-editor.editor"
      }
    ]
  },
  "scripts": {
    "watch": "foy watch",
    "start": "foy watch",
    "test": "vitest run --config test/vitest.config.ts",
    "test:watch": "vitest --config test/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config test/vitest.config.ts",
    "publish:marketplace": "bash scripts/publish-marketplace.sh",
    "release:marketplace": "bash scripts/release-marketplace.sh",
    "pub": "npm run release:marketplace"
  },
  "devDependencies": {
    "@types/node": "^12.12.0",
    "@types/vscode": "^1.110.0",
    "@vitest/coverage-v8": "^4.1.7",
    "foy": "^0.2.5",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "ts-node": "9.1.1",
    "typescript": "4.2.2",
    "vitest": "^4.1.7"
  }
}
