{
  "name": "markdown-editor-extended-settings",
  "displayName": "Markdown Editor — Extended Settings",
  "icon": "media/logo.png",
  "description": "A full-featured WYSIWYG editor for markdown.",
  "version": "0.2.32",
  "publisher": "oleksiiko",
  "author": "Oleksii Konashevich",
  "license": "MIT",
  "private": false,
  "engines": {
    "vscode": "^1.64.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "markdown",
    "editor",
    "wysiwyg",
    "typora",
    "markdown-previewer",
    "markdown-editor"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:markdown-editor.openEditor",
    "onCommand:markdown-editor.openTextEditor",
    "onCustomEditor:markdown-editor.editor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/konashevich/vscode-markdown-editor-extanded-settings.git"
  },
  "main": "out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdown-editor.openEditor",
        "title": "Open with markdown editor",
        "category": "markdown-editor",
        "icon": {
          "light": "media/open-markdown-light.svg",
          "dark": "media/open-markdown-dark.svg"
        }
      },
      {
        "command": "markdown-editor.openTextEditor",
        "title": "Edit in Text Editor",
        "category": "markdown-editor",
        "icon": {
          "light": "media/open-editor-light.svg",
          "dark": "media/open-editor-dark.svg"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "markdown-editor.editor",
        "displayName": "Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md",
            "scheme": "file"
          },
          {
            "filenamePattern": "*.md",
            "scheme": "untitled"
          },
          {
            "filenamePattern": "*.markdown",
            "scheme": "file"
          },
          {
            "filenamePattern": "*.markdown",
            "scheme": "untitled"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceLangId == markdown",
          "command": "markdown-editor.openEditor",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "when": "!isInDiffEditor && activeCustomEditorId != markdown-editor.editor && (resourceExtname == .md || resourceExtname == .markdown) && (resourceScheme == file || resourceScheme == untitled)",
          "command": "markdown-editor.openEditor",
          "group": "navigation@10"
        }
      ],
      "editor/title/context": [
        {
          "when": "activeCustomEditorId == markdown-editor.editor",
          "command": "markdown-editor.openTextEditor",
          "group": "1_open"
        }
      ],
      "commandPalette": [
        {
          "command": "markdown-editor.openEditor",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "markdown-editor",
      "properties": {
        "markdown-editor.imageSaveFolder": {
          "type": "string",
          "default": "assets",
          "description": "Save images to which folder when upload in markdown, default relative to the markdown file, you can set to project root via `${projectRoot}/assets`."
        },
        "markdown-editor.useVscodeThemeColor": {
          "type": "boolean",
          "default": true,
          "description": "Use vscode theme's background color as the markdown editor's background color."
        },
        "markdown-editor.customCss": {
          "type": "string",
          "default": ""
        },
        "markdown-editor.enableFullWidth": {
          "type": "boolean",
          "default": true,
          "description": "Enable full-width layout for the editor (removes max-width centering)."
        }
      }
    },
    "keybindings": [
      {
        "key": "ctrl+alt+e",
        "command": "markdown-editor.openTextEditor",
        "mac": "cmd+ctrl+e",
        "when": "activeCustomEditorId == markdown-editor.editor"
      }
    ]
  },
  "scripts": {
    "watch": "foy watch",
    "start": "foy watch",
    "test": "vitest run --config test/vitest.config.ts",
    "test:watch": "vitest --config test/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config test/vitest.config.ts",
    "publish:marketplace": "bash scripts/publish-marketplace.sh",
    "release:marketplace": "bash scripts/release-marketplace.sh",
    "pub": "npm run release:marketplace"
  },
  "devDependencies": {
    "@types/node": "^12.12.0",
    "@types/vscode": "^1.64.0",
    "@vitest/coverage-v8": "^4.1.7",
    "foy": "^0.2.5",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "ts-node": "9.1.1",
    "typescript": "4.2.2",
    "vitest": "^4.1.7"
  }
}
